datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js" // Certifique-se de que é prisma-client-js
  output   = "../src/generated/prisma"
}

enum Role {
  ADMIN
  USER
}

model User {
  id       Int      @id @default(autoincrement())
  status   Boolean  @default(true)
  createAt DateTime @default(now())
  updateAt DateTime @default(now()) @updatedAt
  role     Role     @default(USER)
  name     String
  email    String   @unique
  posts    Post[]

  @@map("users")
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  subtittle String?
  body      String
  userId    Int
  author    User    @relation(fields: [userId], references: [id])

  @@map("posts")
}
